---
import BaseHead from "@/components/layout/BaseHead.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "@/consts";

interface Props {
    pageTitle: string;
    description?: string;
}
const { pageTitle, description = SITE_DESCRIPTION } = Astro.props;

const lastUpdated = new Date().toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead
            title={`${pageTitle} · ${SITE_TITLE}`}
            description={description}
        />
    </head>
    <body class="bg-white text-slate-800 antialiased">
        <Header />
        <main>
            <article
                class="mx-auto max-w-2xl px-5 py-14 sm:px-6 sm:py-20 lg:py-24"
            >
                <header class="border-b border-slate-200/90 pb-10 sm:pb-12">
                    <p
                        class="mb-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500"
                    >
                        Legal
                    </p>
                    <h1
                        class="text-3xl font-bold tracking-tight text-slate-900 sm:text-[2rem] sm:leading-tight"
                    >
                        {pageTitle}
                    </h1>
                    <p class="mt-3 text-sm text-slate-500">
                        Last updated {lastUpdated}
                    </p>
                </header>
                <div
                    class="mt-10 space-y-12 text-[15px] leading-[1.75] text-slate-600 sm:mt-12 sm:text-base sm:leading-relaxed"
                >
                    <slot />
                </div>
            </article>
        </main>
        <Footer />
    </body>
</html>
