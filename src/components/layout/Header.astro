---
import { SITE_TITLE } from '../../consts';
import HeaderLink from './HeaderLink.astro';
import { Icon } from '../ui/Icon';
import MobileNavigation from './MobileNavigation.tsx';
import WIPBanner from './WIPBanner.astro';
---

<div class="sticky-container">
	<a class="skip-link" href="#main-content">Skip to main content</a>
	<header class="sticky-header">
		<nav aria-label="Primary">
			<div class="site-title"><a href="/">{SITE_TITLE}</a></div>
			
			<!-- Desktop Navigation -->
			<div class="internal-links desktop-only">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/members">Members</HeaderLink>
				<HeaderLink href="/projects">Projects</HeaderLink>
				<HeaderLink href="/events">Events</HeaderLink>
				<HeaderLink href="/opportunities">Opportunities</HeaderLink>
				<HeaderLink href="/contact">Contact</HeaderLink>
				<HeaderLink href="/donate">Donate</HeaderLink>
			</div>
			
			<!-- Mobile Navigation -->
			<div class="mobile-nav-container">
				<MobileNavigation client:load />
			</div>
			
			<div class="social-links desktop-only">
				<a href="https://github.com/HDSI-Lab-3-0/website" target="_blank" rel="noopener noreferrer">
					<span class="sr-only">Go to HDSI Lab GitHub repo</span>
					<Icon icon="Github" size={20} className="text-gray-600 hover:text-gray-900" />
				</a>
			</div>
		</nav>
	</header>
	<WIPBanner />
</div>
<style>
	.sticky-container {
		position: sticky;
		top: 0;
		z-index: 100;
	}

	.skip-link {
		position: absolute;
		left: 1rem;
		top: 0.5rem;
		z-index: 1000;
		transform: translateY(-150%);
		background: rgb(var(--black));
		color: white;
		padding: 0.75rem 1rem;
		border-radius: 0.5rem;
		font-weight: 700;
		text-decoration: none;
		box-shadow: 0 6px 16px rgba(var(--black), 18%);
		transition: transform 0.15s ease;
	}

	.skip-link:focus-visible {
		transform: translateY(0);
		outline: 3px solid var(--focus-ring);
		outline-offset: 3px;
	}

	.sticky-header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	.site-title {
		margin: 0;
		font-size: 1em;
		font-weight: 700;
	}

	.site-title a,
	.site-title a.active {
		text-decoration: none;
		color: rgb(var(--black));
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
	}
	.internal-links {
		display: flex;
		gap: 2rem;
		align-items: center;
	}
	
	.desktop-only {
		display: block;
	}
	
	.mobile-nav-container {
		display: none;
	}
	nav a {
		padding: 1.5rem 0.5rem 0 0.5rem;
		color: rgb(var(--black));
		text-decoration: none;
		font-weight: 400;
		transition: all 0.2s ease;
		position: relative;
		padding-bottom: 1.5rem;
	}
	nav a::after {
		content: "";
		position: absolute;
		bottom: 1.4rem;
		left: 0.5rem;
		right: 0.5rem;
		height: 2px;
		background-color: transparent;
		transition: all 0.2s ease;
	}
	nav a:hover::after {
		background-color: var(--accent);
	}
	nav a.active::after {
		background-color: var(--accent);
	}
	nav a.active {
		font-weight: 700;
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.desktop-only {
			display: none;
		}
		
		.mobile-nav-container {
			display: block;
		}
		
		.internal-links {
			display: none;
		}
		
		nav a {
			padding: 1rem 0.25rem 0 0.25rem;
			padding-bottom: 1rem;
			font-size: 0.9rem;
		}
		nav a::after {
			bottom: 0.9rem;
			left: 0.25rem;
			right: 0.25rem;
		}

		.sticky-container {
			top: 0;
		}
	}

	@media (max-width: 480px) {
		.sticky-container {
			top: 0;
		}
	}
</style>
