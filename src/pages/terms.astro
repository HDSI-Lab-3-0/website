---
import LegalPage from "@/components/legal/LegalPage.astro";
import { SITE_DESCRIPTION } from "@/consts";
---

<LegalPage pageTitle="Terms of Service" description={SITE_DESCRIPTION}>
    <section class="space-y-3">
        <h2 class="text-lg font-semibold tracking-tight text-slate-900">
            1. Acceptance of Terms
        </h2>
        <p>
            By accessing and using this website, you accept and agree to be
            bound by the terms and provision of this agreement. In addition,
            when using this website's particular services, you shall be subject
            to any posted guidelines or rules applicable to such services.
        </p>
    </section>

    <section class="space-y-3">
        <h2 class="text-lg font-semibold tracking-tight text-slate-900">
            2. Intellectual Property
        </h2>
        <p>
            This website and its original content, features, and functionality
            are owned by HDSI Lab 3.0 and are protected by international
            copyright, trademark, patent, trade secret, and other intellectual
            property or proprietary rights laws.
        </p>
        <aside
            class="mt-6 rounded-lg border border-slate-200/90 bg-slate-50/80 px-4 py-4 sm:px-5"
        >
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
                HDSI and UCSD branding
            </p>
            <p class="mt-2 text-slate-700">
                We are authorized to use the logos, trademarks, and branding of
                the Halıcıoğlu Data Science Institute (HDSI) and the University
                of California, San Diego (UCSD) in connection with our
                official activities and representation. Unauthorized use of
                these marks by third parties is strictly prohibited.
            </p>
        </aside>
    </section>

    <section class="space-y-3">
        <h2 class="text-lg font-semibold tracking-tight text-slate-900">
            3. User Conduct
        </h2>
        <p>
            You agree to use the site only for lawful purposes. You are
            prohibited from posting or transmitting to or from this site any
            unlawful, threatening, libelous, defamatory, obscene, pornographic,
            or other material that would violate any law.
        </p>
    </section>

    <section class="space-y-3">
        <h2 class="text-lg font-semibold tracking-tight text-slate-900">
            4. Disclaimer
        </h2>
        <p>
            The materials on HDSI Lab 3.0's website are provided on an "as is"
            basis. HDSI Lab 3.0 makes no warranties, expressed or implied, and
            hereby disclaims and negates all other warranties including, without
            limitation, implied warranties or conditions of merchantability,
            fitness for a particular purpose, or non-infringement of
            intellectual property or other violation of rights.
        </p>
    </section>

    <section class="space-y-3">
        <h2 class="text-lg font-semibold tracking-tight text-slate-900">
            5. Governing Law
        </h2>
        <p>
            Any claim relating to HDSI Lab 3.0's website shall be governed by
            the laws of the State of California without regard to its conflict
            of law provisions.
        </p>
    </section>
</LegalPage>
