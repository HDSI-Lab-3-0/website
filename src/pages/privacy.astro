---
import LegalPage from "@/components/legal/LegalPage.astro";
import { SITE_DESCRIPTION } from "@/consts";
---

<LegalPage pageTitle="Privacy Policy" description={SITE_DESCRIPTION}>
    <section class="space-y-3">
        <h2 class="text-lg font-semibold tracking-tight text-slate-900">
            1. Information Collection
        </h2>
        <p>
            We collect information from you when you visit our site,
            specifically standard web server logs which may include your IP
            address, browser type, and operating system. This information is
            used for internal analytics and to improve our website.
        </p>
    </section>

    <section class="space-y-3">
        <h2 class="text-lg font-semibold tracking-tight text-slate-900">
            2. COPPA (Children's Online Privacy Protection Act)
        </h2>
        <aside
            class="rounded-lg border border-slate-200/90 bg-slate-50/80 px-4 py-4 sm:px-5"
        >
            <p class="text-slate-700">
                Our website is committed to complying with the Children's Online
                Privacy Protection Act (COPPA). We do not knowingly collect or
                solicit personal information from anyone under the age of 13. If
                you are under 13, please do not send any information about
                yourself to us.
            </p>
            <p class="mt-4 text-slate-700">
                In the event that we learn that we have collected personal
                information from a child under age 13 without verification of
                parental consent, we will delete that information as quickly as
                possible. If you believe that we might have any information from
                or about a child under 13, please contact us.
            </p>
        </aside>
    </section>

    <section class="space-y-3">
        <h2 class="text-lg font-semibold tracking-tight text-slate-900">
            3. Media and Photo Policy
        </h2>
        <p>
            We respect the privacy of all individuals featured on our website.
        </p>
        <ul class="mt-4 list-disc space-y-3 pl-5 marker:text-slate-400">
            <li>
                <span class="font-medium text-slate-800">Permissions.</span>
                All photos posted on this website are used with explicit
                permission from the subjects or their legal guardians.
            </li>
            <li>
                <span class="font-medium text-slate-800">Minors.</span>
                For any individuals under the age of majority featured in our
                content, a waiver granting permission has been signed by a
                parent or legal guardian.
            </li>
            <li>
                <span class="font-medium text-slate-800">Protection.</span>
                If a waiver has not been obtained, images of minors are either
                excluded or have been blurred to protect their identity.
            </li>
        </ul>
    </section>

    <section class="space-y-3">
        <h2 class="text-lg font-semibold tracking-tight text-slate-900">
            4. Third-Party Links
        </h2>
        <p>
            Our website may contain links to legal partners and other third-party
            sites. We are not responsible for the privacy practices or the
            content of these other websites.
        </p>
    </section>

    <section class="space-y-3">
        <h2 class="text-lg font-semibold tracking-tight text-slate-900">
            5. Changes to This Privacy Policy
        </h2>
        <p>
            We may update our Privacy Policy from time to time. We will notify
            you of any changes by posting the new Privacy Policy on this page.
        </p>
    </section>

    <section class="space-y-3">
        <h2 class="text-lg font-semibold tracking-tight text-slate-900">
            6. Contact Us
        </h2>
        <p>
            If you have any questions about this Privacy Policy, please contact
            us.
        </p>
    </section>
</LegalPage>
